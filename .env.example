# ============================================================
# 智能情报分析平台 - 环境变量配置模板
# ============================================================
# 使用方式：
#   cp .env.example .env
#   然后按平台说明填入对应的 API Key
# ============================================================

# ============================================================
# 【当前启用平台】— 改这里切换平台
# 可选值：siliconflow / deepseek / qwen / moonshot / minimax /
#          stepfun / hunyuan / doubao / openai / anthropic / google / ollama
# ============================================================
LLM_PROVIDER=siliconflow
LLM_API_KEY=                                        # 填入当前平台的 API Key
LLM_API_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# ---- 词条抽取专用 LLM（extraction）----
EXTRACT_LLM_PROVIDER=siliconflow
EXTRACT_LLM_API_KEY=                                # 可与 LLM_API_KEY 相同
EXTRACT_LLM_BASE_URL=https://api.siliconflow.cn/v1
EXTRACT_LLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# ---- 视觉语言模型 VLM（处理图片、OCR）----
VLM_PROVIDER=siliconflow
VLM_API_KEY=                                        # 可与 LLM_API_KEY 相同
VLM_API_BASE_URL=https://api.siliconflow.cn/v1
VLM_MODEL=Qwen/Qwen2.5-VL-72B-Instruct

# ---- Embedding 模型（转向量数据库）----
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_API_KEY=                                  # 可与 LLM_API_KEY 相同
EMBEDDING_API_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ---- Rerank 模型（重排序，提升检索质量）----
RERANK_PROVIDER=siliconflow
RERANK_API_KEY=                                     # 可与 LLM_API_KEY 相同
RERANK_API_BASE_URL=https://api.siliconflow.cn/v1
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ============================================================
# 【备用平台】 — 填入 API Key 后修改上方 LLM_PROVIDER 即可切换
# ============================================================

# DeepSeek（深度求索）: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# 通义千问（阿里云）: https://dashscope.aliyun.com
QWEN_API_KEY=
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-max
QWEN_EMBEDDING_MODEL=text-embedding-v3

# Moonshot / Kimi: https://platform.moonshot.cn
MOONSHOT_API_KEY=
MOONSHOT_API_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-128k

# MiniMax: https://platform.minimax.chat
MINIMAX_API_KEY=
MINIMAX_API_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-Text-01

# 阶跃星辰 StepFun: https://platform.stepfun.com
STEPFUN_API_KEY=
STEPFUN_API_BASE_URL=https://api.stepfun.com/v1
STEPFUN_MODEL=step-2-16k

# 混元（腾讯）: https://cloud.tencent.com/product/hunyuan
HUNYUAN_API_KEY=
HUNYUAN_API_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
HUNYUAN_MODEL=hunyuan-pro

# 豆包（字节跳动/火山引擎）: https://console.volcengine.com/ark
DOUBAO_API_KEY=
DOUBAO_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-32k

# OpenAI: https://platform.openai.com
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Anthropic Claude: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini: https://aistudio.google.com
GOOGLE_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-1.5-pro
GOOGLE_EMBEDDING_MODEL=text-embedding-004

# Ollama（本地）: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:72b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_VLM_MODEL=llava:13b

# ============================================================
# 【数据库配置】MySQL
# ============================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=intelligence_platform
MYSQL_USER=root
MYSQL_PASSWORD=
