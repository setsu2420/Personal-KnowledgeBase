{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "智能情报分析平台",
  "version": "1.0.0",
  "identifier": "com.intelligence.platform",
  "build": {
    "beforeDevCommand": "cd ../frontend-vue && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../frontend-vue && npm run build",
    "frontendDist": "../frontend-vue/dist"
  },
  "app": {
    "windows": [
      {
        "title": "智能情报分析平台",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "hiddenTitle": true,
        "titleBarStyle": "Transparent"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http: http://localhost:*; img-src 'self' asset: http://asset.localhost https://asset.localhost blob: data:; media-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/java-backend"
    ],
    "resources": [
      "binaries/backend.jar"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW1teV9wdWJsaWNfa2V5X3BsYWNlaG9sZGVyX2Zvcl90YXVyaV91cGRhdGVyX3NpZ25lcgo=",
      "endpoints": [
        "https://raw.githubusercontent.com/setsu2420/Personal-KnowledgeBase/main/latest.json"
      ]
    }
  }
}
